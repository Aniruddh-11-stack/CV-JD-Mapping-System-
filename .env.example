# ============================================================
# CV to JD Mapping System v2 — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Quick start:
#   cp .env.example .env
#   # Fill in your Azure credentials below
#   bash run.sh

# LLM Provider: "azure_openai" | "openai" | "groq" | "gemini"
LLM_PROVIDER=azure_openai

# Azure OpenAI  (required when LLM_PROVIDER=azure_openai)
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-02-01

# OpenAI / Groq / Gemini  (required when LLM_PROVIDER != azure_openai)
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=<your-groq-api-key>
GROQ_MODEL=llama3-70b-8192
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-1.5-flash

# Azure Blob Storage  (optional — for index persistence)
AZURE_STORAGE_CONNECTION_STRING=<your-connection-string>
AZURE_STORAGE_CONTAINER=cv-jd-index
AZURE_STORAGE_CV_PREFIX=cvs/
AZURE_STORAGE_JD_PREFIX=jds/
AZURE_STORAGE_INDEX_PREFIX=faiss_index

# Local Embeddings  (set true to skip Azure embeddings, use HuggingFace)
USE_LOCAL_EMBEDDINGS=false
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# FAISS Index
FAISS_INDEX_PATH=data/faiss_jd_index
FAISS_INDEX_DIM=1536

# Confidence Score Weights (must sum to 1.0)
WEIGHT_SEMANTIC=0.40
WEIGHT_SKILL=0.30
WEIGHT_EXPERIENCE=0.20
WEIGHT_EDUCATION=0.10

# Matching Parameters
TOP_K_MATCHES=3
RETRIEVAL_K=25
GPT_TEMPERATURE=0.2
GPT_MAX_TOKENS=2000

# API Server (FastAPI)
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/cv_jd_system.log

# Optional — Corporate SSL certificate
# SSL_CERT_PATH=/path/to/corporate-ca.pem
